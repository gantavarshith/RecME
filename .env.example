# === RecME Environment Variables ===
# Copy this file to .env and fill in your values.

# TMDB API key (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb API key (https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

# MongoDB connection string
MONGODB_URL=mongodb://127.0.0.1:27017/recme

# JWT secret key (generate a random string: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Gemini / LLM API key (https://aistudio.google.com/app/apikey)
LLM_API_KEY=your_llm_api_key_here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8007

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Path to TMDB credits CSV for content-based recommendations
# CREDITS_CSV_PATH=/path/to/tmdb_5000_credits.csv
